{
    "name": "yilanboy/preview",
    "description": "Generate the preview image",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "allenjiang",
            "email": "allenjianggo@yahoo.com"
        }
    ],
    "scripts": {
        "tests": "./vendor/bin/pest",
        "fmt": "vendor/bin/pint --dirty --parallel",
        "check": [
            "vendor/bin/pint --dirty --test",
            "vendor/bin/phpstan analyse"
        ]
    },
    "keywords": [
        "preview",
        "image"
    ],
    "require": {
        "php": "^8.4",
        "ext-gd": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4.0.0",
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1",
        "ext-fileinfo": "*"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Yilanboy\\Preview\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
